# Copernicus Data Space Ecosystem Credentials
# Get your credentials at: https://dataspace.copernicus.eu
# Dashboard -> User Settings -> OAuth Clients -> Create new

COPERNICUS_CLIENT_ID=your-client-id-here
COPERNICUS_CLIENT_SECRET=your-client-secret-here

# HuggingFace API Token (for intelligent query parsing)
# Get your free token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your-huggingface-token-here
